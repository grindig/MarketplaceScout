# Copy to .env and fill in your Discord bot token
# (Discord Developer Portal -> your application -> Bot -> Token)
DISCORD_BOT_TOKEN=

# Optional for Docker Compose on Linux hosts where your user is not 1000:1000.
# Uncomment and set these to `id -u` / `id -g` so ./json stays writable.
# MARKETPLACESCOUT_UID=1000
# MARKETPLACESCOUT_GID=1000
